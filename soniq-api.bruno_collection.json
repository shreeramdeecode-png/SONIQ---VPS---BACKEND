        },
        {
          "name": "Work Hour Chart",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/client/dashboard/work-hour-chart?from=2026-05-01&to=2026-05-15", "host": ["{{baseUrl}}"], "path": ["api", "client", "dashboard", "work-hour-chart"], "query": [{ "key": "from", "value": "2026-05-01" }, { "key": "to", "value": "2026-05-15" }, { "key": "teamId", "value": "{{teamId}}", "disabled": true }] }, "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }] }
