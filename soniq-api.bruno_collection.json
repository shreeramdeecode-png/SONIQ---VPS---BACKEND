          "name": "Top Apps",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/client/dashboard/top-apps?from=2026-05-15&to=2026-05-15&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "client", "dashboard", "top-apps"], "query": [{ "key": "from", "value": "2026-05-15" }, { "key": "to", "value": "2026-05-15" }, { "key": "limit", "value": "10" }, { "key": "teamId", "value": "{{teamId}}", "disabled": true }] }, "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }] }
        },
        {
          "name": "Activity Table",
