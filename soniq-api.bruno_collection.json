{
  "info": {
    "name": "SoniQ API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "adminToken", "value": "" },
    { "key": "clientToken", "value": "" },
    { "key": "adminRefreshToken", "value": "" },
    { "key": "clientRefreshToken", "value": "" },
    { "key": "orgId", "value": "" },
    { "key": "employeeId", "value": "" },
    { "key": "teamId", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "classificationId", "value": "" },
    { "key": "screenshotId", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Admin / Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.accessToken) bru.setVar('adminToken', r.accessToken);", "if (r.refreshToken) bru.setVar('adminRefreshToken', r.refreshToken);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/auth/login", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"info@deecodes.io\",\n  \"password\": \"Deecodes@321\"\n}" } }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.accessToken) bru.setVar('adminToken', r.accessToken);", "if (r.refreshToken) bru.setVar('adminRefreshToken', r.refreshToken);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/auth/refresh", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}" } }
        },
        {
          "name": "Validate Token",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/auth/validate", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/auth/logout", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}" } }
        }
      ]
    },
    {
      "name": "Admin / Organizations",
      "item": [
        {
          "name": "List Orgs",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/orgs?page=1&pageSize=20", "host": ["{{baseUrl}}"], "path": ["api", "admin", "orgs"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }, { "key": "search", "value": "", "disabled": true }] }, "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Get Org",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Create Org",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.id) bru.setVar('orgId', r.id);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/orgs", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corp\",\n  \"contactEmail\": \"owner@acme.com\",\n  \"industry\": \"Technology\",\n  \"timezone\": \"Asia/Kolkata\",\n  \"planName\": \"pro\",\n  \"monthlyAmount\": 99,\n  \"maxEmployees\": 50,\n  \"maxStorageGb\": 100,\n  \"dataRetentionDays\": 90,\n  \"trialDays\": 30\n}" } }
        },
        {
          "name": "Update Org",
          "request": { "method": "PUT", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corporation\"\n}" } }
        },
        {
          "name": "Suspend Org",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/suspend", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Reactivate Org",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/reactivate", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Delete Org",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Get Org Employees",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/orgs/{{orgId}}/employees?page=1&pageSize=20", "host": ["{{baseUrl}}"], "path": ["api", "admin", "orgs", "{{orgId}}", "employees"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Get Org Teams",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/teams", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Get Org Settings",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/settings", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Update Org Settings",
          "request": { "method": "PUT", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/settings", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"defaultCaptureIntervalMinutes\": 10,\n  \"defaultBlurEnabled\": false,\n  \"defaultStealthEnabled\": false,\n  \"defaultScreenshotEnabled\": true\n}" } }
        },
        {
          "name": "Get Org Billing",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/billing", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Update Org Billing",
          "request": { "method": "PUT", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/billing", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"planName\": \"pro\",\n  \"maxEmployees\": 50,\n  \"maxStorageGb\": 100,\n  \"status\": \"active\",\n  \"expiresAt\": \"2027-01-01T00:00:00.000Z\"\n}" } }
        },
        {
          "name": "Get Audit Logs",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/orgs/{{orgId}}/audit-logs?page=1&pageSize=50", "host": ["{{baseUrl}}"], "path": ["api", "admin", "orgs", "{{orgId}}", "audit-logs"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "50" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Get Agent Mapping",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/agent-mapping", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Upsert Agent Mapping",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/agent-mapping", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"externalOrgId\": \"\",\n  \"apiKey\": \"\",\n  \"webhookSecret\": \"\",\n  \"agentProvider\": \"trackpilots\"\n}" } }
        },
        {
          "name": "Delete Agent Mapping",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/agent-mapping", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Agent Sync",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/orgs/{{orgId}}/agent-sync", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        }
      ]
    },
    {
      "name": "Admin / Dashboard & Platform Settings",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/dashboard/stats", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "List Classifications",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/admin/platform-settings/classifications?page=1&pageSize=50", "host": ["{{baseUrl}}"], "path": ["api", "admin", "platform-settings", "classifications"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "50" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        },
        {
          "name": "Create Classification",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.id) bru.setVar('classificationId', r.id);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/admin/platform-settings/classifications", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"appNamePattern\": \"Slack\",\n  \"appCategory\": \"communication\",\n  \"defaultStatus\": \"neutral\"\n}" } }
        },
        {
          "name": "Update Classification",
          "request": { "method": "PUT", "url": "{{baseUrl}}/api/admin/platform-settings/classifications/{{classificationId}}", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"defaultStatus\": \"productive\"\n}" } }
        },
        {
          "name": "Delete Classification",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/admin/platform-settings/classifications/{{classificationId}}", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }] }
        }
      ]
    },
    {
      "name": "Client / Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.accessToken) bru.setVar('clientToken', r.accessToken);", "if (r.refreshToken) bru.setVar('clientRefreshToken', r.refreshToken);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/login", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@acme.com\",\n  \"password\": \"Employee@123\"\n}" } }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.accessToken) bru.setVar('clientToken', r.accessToken);", "if (r.refreshToken) bru.setVar('clientRefreshToken', r.refreshToken);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/refresh", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{clientRefreshToken}}\"\n}" } }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/logout", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{clientToken}}" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{clientRefreshToken}}\"\n}" } }
        },
        {
          "name": "Forgot Password",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/forgot-password", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@acme.com\"\n}" } }
        },
        {
          "name": "Verify OTP",
          "event": [{ "listen": "test", "script": { "exec": ["const r = res.getBody();", "if (r.resetToken) bru.setVar('resetToken', r.resetToken);"] } }],
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/verify-otp", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@acme.com\",\n  \"otp\": \"123456\"\n}" } }
        },
        {
          "name": "Reset Password",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/reset-password", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPass@123\"\n}" } }
        }
      ]
    },
    {
      "name": "Client / Dashboard",
      "item": [
        {
          "name": "Today Stats",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/client/dashboard/stats", "host": ["{{baseUrl}}"], "path": ["api", "client", "dashboard", "stats"], "query": [{ "key": "teamId", "value": "{{teamId}}", "disabled": true }] }, "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }] }
        },
        {
          "name": "Top Productive Employees",
